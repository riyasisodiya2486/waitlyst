# Authentication
AUTH_SECRET=your-auth-secret-key-here-at-least-32-chars
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# Database - Aurora DSQL
PGHOST=your-aurora-dsql-host.us-east-1.rds.amazonaws.com
PGUSER=admin
PGDATABASE=waitlyst
AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/ROLE_NAME

# Stripe (Optional)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_ID=price_your-stripe-price-id
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI/Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# DynamoDB
DYNAMODB_TABLE_EVENTS=waitlyst-events
