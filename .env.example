# ============================================
# IMPORTANT: .env.example vs .env.development.local
# ============================================
# .env.example: Template file - COMMIT to git - shows what vars are needed
# .env.development.local: Your secrets - DO NOT commit - add to .gitignore
# 
# To set up locally:
# 1. Copy this file: cp .env.example .env.development.local
# 2. Fill in all values in .env.development.local
# 3. Never commit .env.development.local to git
#
# ============================================
# AUTHENTICATION (Email/Password only - NO Google OAuth)
# ============================================
# JWT secret for signing session cookies
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-jwt-secret-key-generate-with-openssl


# ============================================
# DATABASE - Aurora DSQL
# ============================================
PGHOST=your-aurora-dsql-host.us-east-1.rds.amazonaws.com
PGUSER=admin
PGDATABASE=waitlyst
AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/ROLE_NAME

# ============================================
# AI - Groq
# ============================================
GROQ_API_KEY=sk-ant-your-anthropic-api-key

# ============================================
# PAYMENTS - Stripe (Optional)
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_ID=price_your-stripe-price-id

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# DYNAMODB (Event Logging)
# ============================================
DYNAMODB_TABLE_EVENTS=waitlyst-events


